# Build artifacts
/target
**/*.rs.bk
Cargo.lock.bak

# Stub build outputs
/stubs/**/build/
/stubs/**/*.obj
/stubs/**/*.o
/stubs/**/*.blob
/stubs/**/*.lib
/stubs/**/*.exp

# Packed demo outputs (per-platform, all in repo root)
/packed*.exe
/packed*
/demo/packed*.exe
packed_e2e_*

# IDE
.vs/
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Test outputs
/tests/output/
*.packed.exe
/packed*.exe
/demo/packed*.exe
# Stray scratch artefacts left from manual experiments
/__t.exe
/copy.exe
/inspect.json

# Demo test sample (NativeAOT + Avalonia binary, 42 MB).
# Provided externally; place under demo/ before running tests.
/demo/*.exe

# Linux demo binaries (Phase J). The integration tests look for
# `Demo/PatchInstaller` etc.; the binaries are large and provided
# externally rather than tracked in git.
/Demo/

# LLVM 21.1.0 prebuilt dev SDK (~4 GB). Phase A1 needs the headers
# and import libraries that the upstream `clang+llvm-...` archive
# provides. The bootstrap step in the README downloads the archive
# to `.tools/`; we never commit it.
/.tools/

# Phase A1 IR-pass plugin build output (CMake / Ninja).
/tools/obfuscator-passes/build/
/tools/obfuscator-passes/**/*.bc
/tools/obfuscator-passes/**/*.ll
